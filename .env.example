# Database — matches docker-compose.yml by default
DATABASE_URL=postgresql://zapchast:zapchast@localhost:5433/zapchast

JWT_SECRET=change-me-in-production-min-16-chars
JWT_EXPIRES_IN=15m

# Comma-separated origins, or * for reflect request origin (dev)
CORS_ORIGINS=*

# Log OTP to server console (development); do not enable in production
# OTP_DEV_MODE=true

# Throttler defaults (global; OTP uses stricter @Throttle on routes)
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=60

# SMS / OTP — D-011: dev (default, logs code), twilio, or http webhook
# SMS_PROVIDER=dev
#
# Twilio (SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Use either a Messaging Service SID or a From number (E.164)
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=
#
# HTTP aggregator (SMS_PROVIDER=http) — POST JSON; default body:
# {"to":"{{phone}}","message":"{{message}}"} (message = OTP text)
# SMS_HTTP_URL=https://example.com/send-sms
# SMS_HTTP_BODY_JSON={"to":"{{phone}}","message":"{{message}}"}
# SMS_HTTP_HEADERS_JSON={"Authorization":"Bearer your-token"}
#
# Optional template for SMS body (Twilio + http): placeholders {{code}}, {{phone}}
# SMS_OTP_MESSAGE_TEMPLATE=Zapchast code: {{code}}

# S3-compatible presigned uploads (required for POST /uploads/presign)
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=zapchast
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# Optional public base URL for keys if different from presign host
# S3_PUBLIC_URL=

# Expo push — https://expo.dev/accounts/[account]/settings/access-tokens
# Required for POST /v1/admin/push/test and for real offer/request push.
# EXPO_ACCESS_TOKEN=

# Optional
# REDIS_URL=redis://localhost:6379
# PORT=3000

# OpenAPI: UI at /swagger (disabled in production unless true)
# SWAGGER_ENABLED=true

# Dev seed: SEED=true npm run seed (client + admin) or SEED_ADMIN=true (admin only)
# Refuses NODE_ENV=production unless ALLOW_DANGEROUS_SEED=true (D-016).
# OTP verify promotes SEED_ADMIN_PHONE user→admin when NODE_ENV is not production, or when
# LOCAL_ADMIN_OTP=true or ADMIN_OTP_BOOTSTRAP=true (never enable those in real production).
# SEED=true
# SEED_ADMIN_PHONE=+37400000000
# SEED_CLIENT_PHONE=+37400000001
# SEED_ADMIN=true
# LOCAL_ADMIN_OTP=true
# ADMIN_OTP_BOOTSTRAP=true
# ALLOW_DANGEROUS_SEED=true
