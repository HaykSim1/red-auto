# Copy these into Railway → Service → Variables (do not commit secrets).
# Full descriptions: ../docs/deployment-railway.md and ./.env.example

# --- Required ---
NODE_ENV=production
JWT_SECRET=minimum-sixteen-chars-secret

# Linked automatically when Postgres is attached to the service:
# DATABASE_URL=

# --- SMS (required in production; see env.schema superRefine) ---
SMS_PROVIDER=twilio
# Staging only — log OTP in server logs instead of sending SMS (never on public prod):
# SMS_PROVIDER=dev
# ALLOW_LOG_ONLY_SMS_IN_PRODUCTION=true
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=
# SMS_OTP_MESSAGE_TEMPLATE=Zapchast code: {{code}}

# Or HTTP webhook instead of Twilio:
# SMS_PROVIDER=http
# SMS_HTTP_URL=
# SMS_HTTP_HEADERS_JSON={"Authorization":"Bearer ..."}

# --- CORS (set your admin / web origins; avoid * in production) ---
CORS_ORIGINS=https://your-admin.example,https://your-app.web.app

# --- Optional ---
# PORT is set by Railway automatically.
# S3_* / S3_PUBLIC_URL — presigned uploads
# EXPO_ACCESS_TOKEN — push notifications
# SWAGGER_ENABLED=true — expose /swagger in production

# Never in real production:
# OTP_DEV_MODE=true
# LOCAL_ADMIN_OTP=true
# ADMIN_OTP_BOOTSTRAP=true
